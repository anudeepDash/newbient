{
    "redirects": [
        {
            "source": "/admin",
            "has": [{ "type": "host", "value": "artistant.in" }],
            "destination": "/",
            "permanent": false
        },
        {
            "source": "/admin",
            "has": [{ "type": "host", "value": "www.artistant.in" }],
            "destination": "/",
            "permanent": false
        },
        {
            "source": "/admin/:path*",
            "has": [{ "type": "host", "value": "artistant.in" }],
            "destination": "/",
            "permanent": false
        },
        {
            "source": "/admin/:path*",
            "has": [{ "type": "host", "value": "www.artistant.in" }],
            "destination": "/",
            "permanent": false
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
                { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "has": [{ "type": "host", "value": "artistant.in" }],
            "destination": "/artistant"
        },
        {
            "source": "/",
            "has": [{ "type": "host", "value": "www.artistant.in" }],
            "destination": "/artistant"
        },
        {
            "source": "/giveaway/:slug",
            "destination": "/api/og?giveaway=:slug"
        },
        {
            "source": "/forms/:id",
            "destination": "/api/og?formId=:id"
        },
        {
            "source": "/community-join",
            "has": [{ "type": "query", "key": "gig" }],
            "destination": "/api/og"
        },
        {
            "source": "/community-join",
            "has": [{ "type": "query", "key": "gl" }],
            "destination": "/api/og"
        },
        {
            "source": "/community-join",
            "has": [{ "type": "query", "key": "form" }],
            "destination": "/api/og"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "query",
                    "key": "event"
                }
            ],
            "destination": "/api/og"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}